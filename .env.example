# Optional: OpenRouter API key for LLM-enhanced recommendations
# Get a free key at https://openrouter.ai/
# If not set, the app falls back to a robust rule-based engine
OPENROUTER_API_KEY=your_key_here

# Optional: Model to use (default: google/gemini-2.0-flash-001)
LLM_MODEL=google/gemini-2.0-flash-001
